{
  "name": "coffee-menu-website",
  "version": "0.1.0",
  "description": "A mobile-first, responsive coffee menu website built with SolidJS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "solid-js": "^1.8.0",
    "solid-motionone": "^1.0.4",
    "three": "^0.183.2",
    "vanta": "^0.5.24"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-solid": "^0.13.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "terser": "^5.46.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.8.0",
    "wrangler": "^4.77.0"
  }
}
